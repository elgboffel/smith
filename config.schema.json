{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Case Config",
  "description": "Configuration for the case orchestrator harness",
  "type": "object",
  "properties": {
    "models": {
      "type": "object",
      "description": "Per-agent model configuration. Each role can specify a provider and model ID.",
      "properties": {
        "default": { "$ref": "#/$defs/modelConfig" },
        "implementer": { "oneOf": [{ "$ref": "#/$defs/modelConfig" }, { "type": "null" }] },
        "verifier": { "oneOf": [{ "$ref": "#/$defs/modelConfig" }, { "type": "null" }] },
        "reviewer": { "oneOf": [{ "$ref": "#/$defs/modelConfig" }, { "type": "null" }] },
        "closer": { "oneOf": [{ "$ref": "#/$defs/modelConfig" }, { "type": "null" }] },
        "retrospective": { "oneOf": [{ "$ref": "#/$defs/modelConfig" }, { "type": "null" }] },
        "orchestrator": { "oneOf": [{ "$ref": "#/$defs/modelConfig" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "effort": {
      "type": "object",
      "description": "Per-agent reasoning effort (thinking level). Higher levels trade more tokens for deeper reasoning. Unset agents use built-in defaults: scout=low, implementer=medium, verifier=medium, reviewer=high, closer=off, retrospective=low, orchestrator=medium, interviewer=low. Set 'default' to 'off' to disable extended thinking everywhere. A requested level is clamped to what the chosen model supports.",
      "properties": {
        "default": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "scout": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "implementer": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "verifier": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "reviewer": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "closer": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "retrospective": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "orchestrator": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] },
        "interviewer": { "oneOf": [{ "$ref": "#/$defs/effortLevel" }, { "type": "null" }] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "effortLevel": {
      "type": "string",
      "enum": ["off", "minimal", "low", "medium", "high", "xhigh"],
      "description": "Reasoning effort: off disables extended thinking; minimal<low<medium<high<xhigh increase reasoning depth and token use."
    },
    "modelConfig": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "description": "Model provider (e.g., anthropic, google, openai)" },
        "model": { "type": "string", "description": "Model ID (e.g., claude-sonnet-4-20250514, gemini-2.5-pro)" }
      },
      "required": ["provider", "model"],
      "additionalProperties": false
    }
  }
}
