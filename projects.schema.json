{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Case Harness Project Manifest",
  "description": "Manifest of WorkOS open source repositories managed by the case harness",
  "type": "object",
  "required": ["repos"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "evidenceStrategy",
          "path",
          "remote",
          "description",
          "language",
          "packageManager",
          "commands"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Short identifier for the repo (used in task file prefixes)"
          },
          "evidenceStrategy": {
            "type": "string",
            "enum": ["ui-screenshot", "scenario-script", "test-output"],
            "description": "What kind of evidence proves a change works. ui-screenshot: Playwright before/after for apps with UI. scenario-script: consumer script that exercises the changed API for libraries. test-output: test suite + typecheck + build for pure-logic/config changes."
          },
          "path": {
            "type": "string",
            "description": "Relative path from case/ to the repo root"
          },
          "remote": {
            "type": "string",
            "description": "Git remote URL"
          },
          "description": {
            "type": "string",
            "description": "One-line description of the repo's purpose"
          },
          "language": {
            "type": "string",
            "enum": ["typescript", "python", "go", "ruby", "php", "dotnet", "elixir", "kotlin"]
          },
          "packageManager": {
            "type": "string",
            "enum": ["pnpm", "npm", "yarn", "bun", "uv", "pip", "go", "bundler", "composer", "dotnet", "mix", "gradle"]
          },
          "commands": {
            "type": "object",
            "required": ["setup", "test"],
            "properties": {
              "setup": { "type": "string", "description": "Install dependencies" },
              "build": { "type": "string", "description": "Build the project" },
              "test": { "type": "string", "description": "Run tests" },
              "lint": { "type": "string", "description": "Run linter" },
              "typecheck": { "type": "string", "description": "Run type checker" },
              "format": { "type": "string", "description": "Run formatter" }
            },
            "additionalProperties": { "type": "string" }
          },
          "credentials": {
            "type": "string",
            "description": "Path to a sourceable env file with credentials for integration testing. Defaults to ~/.config/case/credentials.",
            "default": "~/.config/case/credentials"
          },
          "verificationNotes": {
            "type": "string",
            "description": "Free-text hints for the verifier agent — auth flows, env var names, gotchas. Injected into the verifier context."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
